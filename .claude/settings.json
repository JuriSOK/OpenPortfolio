{
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read(./**)",
      "Edit(./**)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)"
    ],
    "ask": [
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(npm install*)",
      "Bash(npm uninstall*)",
      "Bash(rm *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./private/**)",
      "Read(./config/credentials*)",
      "Read(./.claude/settings.local.json)",
      "Bash(git push --force*)",
      "Bash(git checkout main && git merge*)"
    ]
  }
}
